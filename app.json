{
  "expo": {
    "name": "KE SHOP",
    "slug": "ke-shop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/icon.png",
    "scheme": "keshop",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/logo/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/logo/icon.png",
        "backgroundImage": "./assets/logo/icon.png",
        "monochromeImage": "./assets/logo/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.kiala_emanuel.keshop"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/logo/icon.png",
          "imageWidth": 76
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0d11af0c-84f2-47b5-9942-076fe21afd6c"
      }
    }
  }
}
